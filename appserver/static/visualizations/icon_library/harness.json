{
  "label": "Icon Library",
  "defaultSize": { "width": 400, "height": 400 },
  "noDataMessage": "No data — icon renders from config only",
  "dependencies": [],
  "fields": [
    { "name": "icon", "label": "Icon Name", "type": "text", "default": "security" },
    { "name": "color", "label": "Color Override (hex)", "type": "text", "default": "" },
    { "name": "label", "label": "Label Override", "type": "text", "default": "" },
    { "name": "value", "label": "Value (threshold)", "type": "slider", "min": 0, "max": 100, "step": 1, "default": 95 }
  ],
  "formatter": [
    { "name": "iconName", "label": "Icon (Popular)", "type": "select", "default": "home", "options": [
      { "v": "home", "l": "home" },
      { "v": "search", "l": "search" },
      { "v": "settings", "l": "settings" },
      { "v": "favorite", "l": "favorite" },
      { "v": "star", "l": "star" },
      { "v": "check_circle", "l": "check_circle" },
      { "v": "cancel", "l": "cancel" },
      { "v": "info", "l": "info" },
      { "v": "warning", "l": "warning" },
      { "v": "error", "l": "error" },
      { "v": "lock", "l": "lock" },
      { "v": "person", "l": "person" },
      { "v": "group", "l": "group" },
      { "v": "security", "l": "security" },
      { "v": "shield", "l": "shield" },
      { "v": "notifications", "l": "notifications" },
      { "v": "email", "l": "email" },
      { "v": "cloud", "l": "cloud" },
      { "v": "storage", "l": "storage" },
      { "v": "database", "l": "database" },
      { "v": "dns", "l": "dns" },
      { "v": "dashboard", "l": "dashboard" },
      { "v": "analytics", "l": "analytics" },
      { "v": "trending_up", "l": "trending_up" },
      { "v": "speed", "l": "speed" },
      { "v": "bolt", "l": "bolt" },
      { "v": "memory", "l": "memory" },
      { "v": "terminal", "l": "terminal" },
      { "v": "code", "l": "code" },
      { "v": "bug_report", "l": "bug_report" },
      { "v": "hub", "l": "hub" },
      { "v": "router", "l": "router" },
      { "v": "wifi", "l": "wifi" },
      { "v": "lan", "l": "lan" },
      { "v": "devices", "l": "devices" },
      { "v": "computer", "l": "computer" },
      { "v": "smartphone", "l": "smartphone" },
      { "v": "location_on", "l": "location_on" },
      { "v": "rocket_launch", "l": "rocket_launch" },
      { "v": "task_alt", "l": "task_alt" },
      { "v": "flag", "l": "flag" },
      { "v": "emergency", "l": "emergency" }
    ]},
    { "name": "customIcon", "label": "Custom Icon Name", "type": "text", "default": "" },
    { "name": "iconColor", "label": "Icon Color", "type": "color", "default": "#06B6D4" },
    { "name": "iconSize", "label": "Icon Size (0=auto)", "type": "text", "default": "0" },
    { "name": "hAlign", "label": "Horizontal Align", "type": "radio", "options": ["left", "center", "right"], "default": "center" },
    { "name": "vAlign", "label": "Vertical Align", "type": "radio", "options": ["top", "center", "bottom"], "default": "center" },
    { "name": "rotation", "label": "Rotation (degrees)", "type": "text", "default": "0" },
    { "name": "showLabel", "label": "Show Label", "type": "radio", "options": ["yes", "no"], "default": "no" },
    { "name": "labelText", "label": "Label Text", "type": "text", "default": "" },
    { "name": "labelSize", "label": "Label Size (0=auto)", "type": "text", "default": "0" },
    { "name": "labelColor", "label": "Label Color", "type": "color", "default": "#94A3B8" },
    { "name": "bgShape", "label": "Background Shape", "type": "select", "default": "none", "options": [
      { "v": "none", "l": "None" },
      { "v": "circle", "l": "Circle" },
      { "v": "rounded_rect", "l": "Rounded Rectangle" },
      { "v": "square", "l": "Square" }
    ]},
    { "name": "bgColor", "label": "Background Color", "type": "color", "default": "#1E293B" },
    { "name": "bgOpacity", "label": "Background Opacity", "type": "text", "default": "1" },
    { "name": "bgPadding", "label": "Background Padding", "type": "text", "default": "16" },
    { "name": "bgRadius", "label": "Corner Radius", "type": "text", "default": "12" },
    { "name": "shadow", "label": "Shadow", "type": "radio", "options": ["yes", "no"], "default": "no" },
    { "name": "shadowColor", "label": "Shadow Color", "type": "color", "default": "#000000" },
    { "name": "shadowBlur", "label": "Shadow Blur", "type": "text", "default": "8" },
    { "name": "shadowOffsetX", "label": "Shadow X", "type": "text", "default": "0" },
    { "name": "shadowOffsetY", "label": "Shadow Y", "type": "text", "default": "4" },
    { "name": "glow", "label": "Glow", "type": "radio", "options": ["yes", "no"], "default": "no" },
    { "name": "glowColor", "label": "Glow Color", "type": "color", "default": "#06B6D4" },
    { "name": "glowSize", "label": "Glow Size", "type": "text", "default": "12" },
    { "name": "drilldown", "label": "Enable Drilldown", "type": "radio", "options": ["yes", "no"], "default": "no" },
    { "name": "drilldownUrl", "label": "Drilldown URL", "type": "text", "default": "" },
    { "name": "drilldownNewTab", "label": "Drilldown New Tab", "type": "radio", "options": ["yes", "no"], "default": "yes" }
  ],
  "data": {
    "mode": "single_row",
    "columns": ["icon", "color", "label", "value"]
  }
}
